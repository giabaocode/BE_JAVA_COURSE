# Supabase config — copy this file to .env.local and fill in your project values.
# (Settings → API in your Supabase dashboard.)
# If left empty, the app still works locally; only DB-backed features (Feynman,
# Vault, Heatmap, Bug Journal, Email reminder) will degrade to read-only mode.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
